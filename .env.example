# Backend
PORT=3000

# Allowed frontend origin for socket CORS (set this to your GitHub Pages URL in prod)
# Example: https://yourname.github.io
FRONTEND_ORIGIN=

# Optional: custom dev frontend origin
# VITE_DEV_ORIGIN=http://localhost:5173

# Optional extra comma-separated CORS origins
# Example: http://192.168.1.9:5173,https://strikercode08.github.io
CORS_ORIGINS=

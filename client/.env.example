# In development, point frontend to backend server
VITE_SOCKET_ORIGIN=http://localhost:3000

# Optional explicit audio base URL. If omitted, falls back to VITE_SOCKET_ORIGIN.
# Use your Render backend URL in production builds.
# Example:
# VITE_AUDIO_BASE_URL=https://your-render-service.onrender.com
VITE_AUDIO_BASE_URL=

# GitHub Pages base path:
# - User/Org site: /
# - Project site: /<repo-name>/
# VITE_BASE_PATH=/
